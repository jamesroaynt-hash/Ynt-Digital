HOST=0.0.0.0
PORT=3001
JWT_SECRET=change-this-secret-for-office-use
FRONTEND_ORIGINS=http://192.168.1.25,http://office-dashboard
DATABASE_URL=
POSTGRES_SSL=true
RAILWAY_BACKUP_DATABASE_URL=
BACKUP_SOURCE_DATABASE_URL=
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_SHEET_NAME=Orders
GOOGLE_SHEETS_CLIENT_EMAIL=
GOOGLE_SHEETS_PRIVATE_KEY=
GOOGLE_SHEETS_SYNC_MODE=manual
GOOGLE_SHEETS_SYNC_ENABLED=false
GOOGLE_SHEETS_SYNC_INTERVAL_MS=300000
PANCAKE_POS_SYNC_ENABLED=false
PANCAKE_POS_SYNC_INTERVAL_MS=300000
PANCAKE_POS_SYNC_PAGE_SIZE=100
PANCAKE_POS_WEBHOOK_SECRET=
POS_STORE_RAW_PAYLOADS=true
POS_CLEAN_MALFORMED_ORDERS=false
# --- SQLite location & cloud backup (only used when DATABASE_URL is unset) ---
# Point SQLITE_PATH at a Railway persistent volume so the DB survives redeploys
# without re-uploading the whole file to R2 on every write (the big egress sink).
# e.g. mount a volume at /data, then: SQLITE_PATH=/data/ynt.db
SQLITE_PATH=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_SQLITE_BACKUP_KEY=ynt-dashboard/ynt.db
R2_SQLITE_BACKUP=true
# Backup cadence (egress control):
#  - SQLITE_BACKUP_ON_WRITE=false  -> retire write-triggered uploads (use with a volume)
#  - SQLITE_BACKUP_INTERVAL_MS     -> fixed disaster-recovery snapshot, e.g. 86400000 (daily)
#  - SQLITE_BACKUP_MIN_INTERVAL_MS -> throttle for write-triggered mode (default 900000 = 15m)
# Recommended with a Railway volume: SQLITE_BACKUP_ON_WRITE=false + SQLITE_BACKUP_INTERVAL_MS=86400000
SQLITE_BACKUP_ON_WRITE=false
SQLITE_BACKUP_INTERVAL_MS=
SQLITE_BACKUP_MIN_INTERVAL_MS=900000
