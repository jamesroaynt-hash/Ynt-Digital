{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" }
  ],
  "functions": {
    "api/index.js": {
      "includeFiles": "backend/db/*.sql,frontend/**"
    }
  },
  "crons": [
    {
      "path": "/api/public/integrations/google-sheets/cron",
      "schedule": "*/5 * * * *"
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/api/index.js" }
  ]
}
